# ARGUS — Local environment variables
# Copy this file to .env and fill in your own values
# NEVER commit .env (it's in .gitignore)

# === LLM Provider (BYOK) ===
# Get your free NVIDIA NIM key at: https://build.nvidia.com/
# Format: nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ARGUS_NIM_KEY=nvapi-your-key-here

# Default model (any NVIDIA NIM model works)
ARGUS_NIM_MODEL=meta/llama-3.1-70b-instruct
ARGUS_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# === Database (Supabase Postgres) ===
# Get from your Supabase project → Settings → Database → Connection string
# Format: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/argus_dev

# === GitHub (for posting comments, fetching PRs) ===
# Personal access token with `repo` scope
GITHUB_TOKEN=ghp-your-token-here

# === Optional: Image generation (DALL-E 3 via OpenAI) ===
# OPENAI_API_KEY=sk-your-key-here

# === Optional: Avatar video (HeyGen or D-ID) ===
# HEYGEN_API_KEY=your-key-here
# DID_API_KEY=your-key-here

# === Server config ===
ARGUS_API_PORT=8080
ARGUS_DASHBOARD_PORT=3000
ARGUS_LOG=info
RUST_LOG=info,argus=debug
